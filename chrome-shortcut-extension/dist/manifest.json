{
  "manifest_version": 3,
  "name": "테코탭",
  "version": "1.0.0",
  "description": "우아한테크코스 크루를 위한 바로가기 모음 🪐",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "테코탭",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "theme_icons": [
      {
        "light": "icons/icon16.png",
        "dark": "icons/icon16_dark.png",
        "size": 16
      },
      {
        "light": "icons/icon48.png",
        "dark": "icons/icon48_dark.png",
        "size": 48
      }
    ]
  }
}
